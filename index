<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Supabase 文本记录器</title>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    body {
      font-family: Arial, sans-serif;
      max-width: 900px;
      margin: 30px auto;
      padding: 0 16px;
      background: #f8fafc;
      line-height: 1.6;
    }
    h1 { margin-bottom: 8px; }
    .hint { color: #666; font-size: 14px; margin-bottom: 20px; }
    .panel {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 16px;
      margin-top: 18px;
    }
    textarea, button {
      width: 100%;
      box-sizing: border-box;
      padding: 10px;
      font-size: 14px;
      border-radius: 8px;
      border: 1px solid #d1d5db;
      margin-top: 8px;
    }
    textarea {
      min-height: 160px;
      resize: vertical;
    }
    button {
      background: #2563eb;
      color: white;
      border: none;
      cursor: pointer;
    }
    button:hover {
      background: #1d4ed8;
    }
    .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 12px;
    }
    #status {
      white-space: pre-wrap;
      color: #111827;
    }
    .record {
      padding: 12px 0;
      border-bottom: 1px solid #e5e7eb;
    }
    .record:last-child {
      border-bottom: none;
    }
    .meta {
      color: #6b7280;
      font-size: 12px;
      margin-bottom: 6px;
    }
    .content {
      white-space: pre-wrap;
      word-break: break-word;
    }
    .empty {
      color: #6b7280;
    }
  </style>
</head>
<body>
  <h1>Supabase 文本记录器</h1>
  <div class="hint">输入文本后保存到 Supabase，并可读取最近记录。</div>

  <div class="panel">
    <strong>输入文本</strong>
    <textarea id="content" placeholder="请输入要保存的内容"></textarea>
    <div class="row">
      <button id="saveBtn">保存文本</button>
      <button id="loadBtn">读取最近记录</button>
    </div>
  </div>

  <div class="panel">
    <strong>状态信息</strong>
    <div id="status">页面已加载。</div>
  </div>

  <div class="panel">
    <strong>最近记录</strong>
    <div id="records" class="empty">暂无数据</div>
  </div>

  <script>
    const SUPABASE_URL = "https://efljgmrwqjndofsutkrp.supabase.co";
    const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVmbGpnbXJ3cWpuZG9mc3V0a3JwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODExNzIzMjksImV4cCI6MjA5Njc0ODMyOX0.JnM9YbCuc5efGm6xIyrHUmVPdDNEHn1qLdxQsBEaViU";
    const TABLE_NAME = "text_notes";

    const supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

    const contentEl = document.getElementById("content");
    const statusEl = document.getElementById("status");
    const recordsEl = document.getElementById("records");

    function setStatus(message) {
      statusEl.textContent = message;
    }

    function escapeHtml(text) {
      return text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function renderRecords(rows) {
      if (!rows || rows.length === 0) {
        recordsEl.innerHTML = '<div class="empty">暂无记录</div>';
        return;
      }

      recordsEl.innerHTML = rows.map(row => `
        <div class="record">
          <div class="meta">ID: ${row.id} | ${row.created_at}</div>
          <div class="content">${escapeHtml(row.content || "")}</div>
        </div>
      `).join("");
    }

    async function saveText() {
      const content = contentEl.value.trim();

      if (!content) {
        setStatus("保存失败：文本内容不能为空。");
        return;
      }

      setStatus("正在保存...");

      try {
        const { data, error, status, statusText } = await supabaseClient
          .from(TABLE_NAME)
          .insert([{ content: content }])
          .select();

        if (error) {
          throw new Error(
            `状态码: ${status || "未知"}\n` +
            `状态描述: ${statusText || "未知"}\n` +
            `错误信息: ${error.message}`
          );
        }

        contentEl.value = "";
        setStatus("保存成功。");
        console.log("保存结果：", data);
        await loadRecords();
      } catch (err) {
        setStatus("保存失败：\n" + err.message);
        console.error("保存失败详情：", err);
      }
    }

    async function loadRecords() {
      setStatus("正在读取记录...");

      try {
        const { data, error, status, statusText } = await supabaseClient
          .from(TABLE_NAME)
          .select("id, content, created_at")
          .order("id", { ascending: false })
          .limit(20);

        if (error) {
          throw new Error(
            `状态码: ${status || "未知"}\n` +
            `状态描述: ${statusText || "未知"}\n` +
            `错误信息: ${error.message}`
          );
        }

        renderRecords(data);
        setStatus(`读取成功，共 ${data.length} 条。`);
      } catch (err) {
        setStatus("读取失败：\n" + err.message);
        console.error("读取失败详情：", err);
      }
    }

    document.getElementById("saveBtn").addEventListener("click", saveText);
    document.getElementById("loadBtn").addEventListener("click", loadRecords);

    loadRecords();
  </script>
</body>
</html>
